<!DOCTYPE html>
<html lang="ko">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{% block title %}Boilerplate Template{% endblock %}</title>

  <!-- Pretendard GOV Font CDN -->
  <link rel="stylesheet" as="style" crossorigin href="https://cdn.jsdelivr.net/gh/orioncactus/pretendard@v1.3.9/dist/web/static/pretendard-gov.min.css" />

  <!-- Global SCSS Stylesheet -->
  <link rel="stylesheet" href="/src/scss/main.scss" />

  <!-- Extra Head Block -->
  {% block head %}{% endblock %}
</head>
<body>
  <div id="app">
    <header class="header">
      <div class="container">
        <h1 class="logo"><a href="/">Web Template</a></h1>
        
        <!-- Desktop Navigation -->
        <nav class="nav desktop-nav">
          <a href="/" class="nav-link">Home</a>
          <a href="#" class="nav-link">About</a>
          <a href="#" class="nav-link">Services</a>
          <a href="#" class="nav-link">Contact</a>
        </nav>

        <!-- Popup Util Button -->
        <button type="button" class="util-pop" id="btnOpenPop" aria-label="팝업 열기">
          POPUP <span class="num">0</span>
        </button>

        <!-- Hamburger Button -->
        <button class="hamburger-btn" aria-label="메뉴 열기">
          <span></span>
          <span></span>
          <span></span>
        </button>
      </div>

      <!-- Mobile Navigation Panel -->
      <div class="mobile-nav-panel">
        <nav class="mobile-nav">
          <a href="/" class="mobile-nav-link">Home</a>
          <a href="#" class="mobile-nav-link">About</a>
          <a href="#" class="mobile-nav-link">Services</a>
          <a href="#" class="mobile-nav-link">Contact</a>
        </nav>
      </div>
    </header>

    <main class="main-content">
      {% block content %}{% endblock %}
    </main>

    <footer class="footer">
      <div class="container">
        <p>&copy; 2026 Web Template. All rights reserved.</p>
      </div>
    </footer>
  </div>

  <!-- Global JS Entrypoint -->
  <script type="module" src="/src/js/main.js"></script>
</body>
</html>
